# Ferramentas e configuração interna — não fazem parte do pacote publicado
.vscode/**
.github/**
.gitignore

# Documentação interna — não é necessária pra rodar o tema
docs/**
reference/**

# Build/tooling que não roda em runtime (o tema é só JSON declarativo)
tsconfig.json
**/*.map

# Nunca inclua o próprio pacote gerado
*.vsix
