<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================
     ARQUIVO DE TESTE - PREVIEW DO TEMA "Esron Dark"
     Cada bloco comentado indica a categoria testada
     ============================================================ -->

<!-- ========== Elemento raiz com namespaces (esperado: prefixo na cor de namespace #81A1C1) ========== -->
<empresa xmlns="http://esron.dev/schema/empresa"
         xmlns:esron="http://esron.dev/schema/custom"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://esron.dev/schema/empresa empresa.xsd">

    <!-- ========== Tags (esperado: mesma cor de elemento HTML, #5FA8D3) ========== -->
    <funcionarios>

        <!-- ========== Atributos (esperado: mesma cor de atributo HTML, #B48EAD) ========== -->
        <pessoa id="1" ativo="true" tipo="funcionario">
            <nome>Esron</nome>
            <idade>30</idade>
            <cargo>Desenvolvedor</cargo>
            <salario moeda="BRL">5000.00</salario>

            <!-- ========== Elemento com prefixo de namespace customizado ========== -->
            <esron:metadados>
                <esron:criadoEm>2026-07-19</esron:criadoEm>
                <esron:versao>1.0</esron:versao>
            </esron:metadados>
        </pessoa>

        <pessoa id="2" ativo="false" tipo="funcionario">
            <nome>Gemini</nome>
            <idade>25</idade>
            <cargo>Analista</cargo>
            <salario moeda="BRL">4200.50</salario>
        </pessoa>

        <!-- ========== Elemento auto-fechado ========== -->
        <pessoa id="3" ativo="true" tipo="estagiario" />

    </funcionarios>

    <!-- ========== CDATA (esperado: mesma cor de string, texto bruto sem parsing) ========== -->
    <observacoes>
        <![CDATA[
            Este texto pode conter <tags> e & símbolos especiais
            sem precisar de escape, porque está dentro de um CDATA.
        ]]>
    </observacoes>

    <!-- ========== Entidades XML ========== -->
    <nota>Salário &amp; benefícios inclusos &lt;conforme contrato&gt;</nota>

    <!-- ========== Lista simples (repetição de tag) ========== -->
    <cores>
        <cor>vermelho</cor>
        <cor>verde</cor>
        <cor>azul</cor>
    </cores>

</empresa>