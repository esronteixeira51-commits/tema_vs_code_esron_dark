{
    "$schema": "https://json-schema.org/draft/2020-12/schema",

    "name": "Esron Dark",

    "displayName": "Esron Dark Theme",

    "description": "Professional VS Code theme inspired by COSMIC.",

    "version": "1.0.0",

    "publisher": "esron",

    "license": "MIT",

    "homepage": "https://esron.dev",

    "repository": {
        "type": "git",
        "url": "https://github.com/esron/esron-dark"
    },

    "bugs": {
        "url": "https://github.com/esron/esron-dark/issues"
    },

    "author": {
        "name": "Esron",
        "email": "esron@example.com",
        "website": "https://esron.dev"
    },

    "keywords": [
        "theme",
        "vscode",
        "dark",
        "cosmic",
        "developer"
    ],

    "engines": {
        "vscode": "^1.105.0"
    },

    "galleryBanner": {
        "color": "#1D1F23",
        "theme": "dark"
    },

    "colors": {
        "background": "#1D1F23",
        "foreground": "#D8DEE9",
        "keyword": "#7A9FE6",
        "type": "#D16D6D",
        "function": "#5A7FBF",
        "builtin": "#88C0D0",
        "string": "#A3BE8C",
        "number": "#D08770",
        "comment": "#6C7480"
    },

    "features": {
        "semanticHighlighting": true,
        "italicComments": true,
        "boldKeywords": true,
        "highContrast": false,
        "transparentBackground": false
    },

    "window": {
        "width": 1920,
        "height": 1080,
        "fullscreen": false,
        "scale": 1.25
    },

    "performance": {
        "startup": 0.42,
        "memoryMB": 512,
        "threads": 8
    },

    "languages": [
        {
            "name": "Python",
            "extension": ".py",
            "enabled": true
        },
        {
            "name": "Rust",
            "extension": ".rs",
            "enabled": true
        },
        {
            "name": "Go",
            "extension": ".go",
            "enabled": true
        },
        {
            "name": "Lua",
            "extension": ".lua",
            "enabled": true
        },
        {
            "name": "PowerShell",
            "extension": ".ps1",
            "enabled": true
        }
    ],

    "numbers": {
        "integer": 42,
        "negative": -10,
        "float": 3.1415926535,
        "scientific": 1.25e6,
        "zero": 0
    },

    "boolean": {
        "trueValue": true,
        "falseValue": false
    },

    "nullExample": null,

    "paths": {
        "linux": "/home/esron/projects",
        "windows": "C:\\Users\\Esron\\Projects",
        "macos": "/Users/esron/Projects"
    },

    "unicode": {
        "portuguese": "Olá Mundo",
        "japanese": "こんにちは",
        "emoji": "🚀🔥💻"
    },

    "matrix": [
        [1, 2, 3],
        [4, 5, 6],
        [7, 8, 9]
    ],

    "nested": {
        "level1": {
            "level2": {
                "level3": {
                    "level4": {
                        "value": "Deep"
                    }
                }
            }
        }
    },

    "terminal": {
        "profiles": {
            "bash": {
                "path": "/bin/bash"
            },
            "powershell": {
                "path": "pwsh.exe"
            }
        }
    },

    "extensions": [
        "ms-python.python",
        "rust-lang.rust-analyzer",
        "golang.go",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml"
    ],

    "tasks": [
        {
            "label": "Build",
            "command": "npm run build"
        },
        {
            "label": "Test",
            "command": "npm test"
        },
        {
            "label": "Package",
            "command": "vsce package"
        }
    ],

    "theme": {
        "ui": {
            "editor": "#1D1F23",
            "sidebar": "#191B1F",
            "activityBar": "#191B1F",
            "statusBar": "#191B1F"
        },

        "syntax": {
            "keyword": "#7A9FE6",
            "type": "#D16D6D",
            "function": "#5A7FBF",
            "builtin": "#88C0D0",
            "variable": "#D8DEE9",
            "string": "#A3BE8C",
            "number": "#D08770",
            "comment": "#6C7480"
        }
    }
}